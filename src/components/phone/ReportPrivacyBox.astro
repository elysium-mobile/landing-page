---
/**
 * ReportPrivacyBox — small "Identidad protegida" row with a faux toggle.
 *
 * Pure decoration; the toggle is a static green pill, no interactivity wired.
 */
import { Icon } from 'astro-icon/components';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations(Astro.currentLocale);
---

<div class="flex items-center gap-3 bg-paper rounded-2xl px-3 py-2.5 border border-line">
  <div class="w-8 h-8 rounded-lg grid place-items-center shrink-0 bg-mint text-teal-deep">
    <Icon name="shield" width={16} height={16} />
  </div>
  <div class="flex-1 min-w-0">
    <div class="text-[12px] font-semibold text-navy leading-tight">{t('cf.report.privacy.title')}</div>
    <div class="text-[10px] text-text-soft mt-0.5">{t('cf.report.privacy.sub')}</div>
  </div>
  <!-- Faux toggle: pill with a circle pinned to the right. Always on. -->
  <span class="relative inline-block w-8 h-4 rounded-full bg-teal shrink-0">
    <span class="absolute top-0.5 right-0.5 w-3 h-3 rounded-full bg-white"></span>
  </span>
</div>
