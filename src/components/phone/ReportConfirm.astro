---
/**
 * ReportConfirm — full-cover overlay shown on stage 3 ("Reporte enviado").
 *
 * Slides in over the report screen with a check icon, confirmation copy, and
 * a TICKET pill. Visibility is controlled by a `data-active` attribute that
 * ReportPhone toggles based on the broadcast scenario step.
 */
import { Icon } from 'astro-icon/components';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations(Astro.currentLocale);
---

<div
  data-report-confirm
  class="absolute inset-0 z-30 flex flex-col items-center justify-center text-center px-6 bg-white opacity-0 pointer-events-none transition-opacity duration-300 data-[active=true]:opacity-100 data-[active=true]:pointer-events-auto"
>
  <div class="w-16 h-16 rounded-full grid place-items-center bg-mint text-teal-deep mb-4">
    <Icon name="check" width={32} height={32} />
  </div>
  <h3 class="m-0 mb-2 text-[18px] font-bold text-navy">{t('cf.report.confirm.title')}</h3>
  <p class="m-0 mb-5 text-[12px] text-text-soft leading-snug max-w-[230px]">
    {t('cf.report.confirm.body')}
  </p>
  <span
    class="inline-block px-3 py-1.5 rounded-md bg-paper border border-line text-[11px] font-mono font-semibold tracking-wider text-navy"
  >
    {t('cf.report.ticket')}
  </span>
</div>
