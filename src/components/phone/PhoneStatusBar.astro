---
/**
 * PhoneStatusBar — fake iOS-style status bar (time + signal + battery).
 *
 * The two SVGs are inlined here because they're trivial and don't deserve their
 * own files in `src/icons/`. Both render at fixed sizes; no scaling needed.
 */
interface Props {
  /** Time text shown at the top-left. Convention is the design's "9:41". */
  time?: string;
}
const { time = '9:41' } = Astro.props;
---

<div class="flex items-center justify-between h-11 px-5 pl-5 text-[12px] font-semibold text-ink shrink-0">
  <span>{time}</span>
  <div class="flex gap-1 items-center opacity-85">
    <!-- Signal-strength bars -->
    <svg width="16" height="11" viewBox="0 0 16 11" fill="currentColor">
      <rect x="0" y="6" width="3" height="5" rx="0.5"/>
      <rect x="4" y="4" width="3" height="7" rx="0.5"/>
      <rect x="8" y="2" width="3" height="9" rx="0.5"/>
      <rect x="12" y="0" width="3" height="11" rx="0.5"/>
    </svg>
    <!-- Battery -->
    <svg width="20" height="10" viewBox="0 0 20 10" fill="none" stroke="currentColor" stroke-width="1">
      <rect x="0.5" y="0.5" width="16" height="9" rx="2"/>
      <rect x="2" y="2" width="13" height="6" rx="1" fill="currentColor"/>
      <rect x="17" y="3" width="2" height="4" rx="1" fill="currentColor"/>
    </svg>
  </div>
</div>
