---
/**
 * SiteFooter — dark gradient footer with brand block + 3 link columns + meta row.
 *
 * The 4-column grid collapses to 2 columns under 768px. Link arrays are built
 * locally via `t()` so they translate alongside everything else.
 */
import Logo from '../brand/Logo.astro';
import SocialLinks from './SocialLinks.astro';
import FooterColumn from './FooterColumn.astro';
import { useTranslations, localizedPath } from '../../i18n/utils';

const t = useTranslations(Astro.currentLocale);
const lp = (path: string) => localizedPath(Astro.currentLocale, path);

const product = [
  { label: t('footer.product.benefits'), href: lp('/#benefits') },
  { label: t('footer.product.how'), href: lp('/how-it-works') },
  { label: t('footer.product.integrations'), href: '#' },
  { label: t('footer.product.pricing'), href: '#pricing' },
  { label: t('footer.product.news'), href: '#' },
];

const startup = [
  { label: t('footer.company.about'), href: '#' },
  { label: t('footer.company.cases'), href: '#' },
  { label: t('footer.company.contact'), href: '#' },
  { label: t('footer.company.careers'), href: '#' },
];

const legal = [
  { label: t('footer.legal.privacy'), href: '#' },
  { label: t('footer.legal.terms'), href: '#' },
  { label: t('footer.legal.security'), href: '#' },
  { label: t('footer.legal.dpa'), href: '#' },
  { label: t('footer.legal.anonymity'), href: '#' },
];
---

<footer
  class="mt-30 py-16 pb-10 text-white/86"
  style="background: linear-gradient(180deg, var(--color-navy-deep) 0%, var(--color-navy-deeper) 100%);"
>
  <div class="shell">
    <div class="grid gap-12 pb-12 border-b border-white/10 md:grid-cols-[1.4fr_1fr_1fr_1fr] grid-cols-2">
      <div>
        <Logo invert href={lp('/')} />
        <p class="mt-3.5 text-[14px] leading-[1.6] text-white/66 max-w-[320px]">
          {t('footer.tagline')}
        </p>
        <SocialLinks />
      </div>
      <FooterColumn title={t('footer.col.product')} links={product} />
      <FooterColumn title={t('footer.col.company')} links={startup} />
      <FooterColumn title={t('footer.col.legal')} links={legal} />
    </div>
    <div class="flex items-center justify-between pt-7 text-[12px] text-white/50 flex-wrap gap-3">
      <span>{t('footer.copy')}</span>
      <span class="inline-flex items-center gap-2">
        {t('footer.by.prefix')}
        <strong class="text-white font-semibold tracking-[0.02em]">Elysium</strong>
      </span>
    </div>
  </div>
</footer>
