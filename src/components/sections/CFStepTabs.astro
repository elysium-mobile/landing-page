---
/**
 * CFStepTabs — three pill-tabs that anchor-link to the three scenario sections.
 *
 * Pure markup: each tab is just an `<a href="#anchor">`. The "active" tab is
 * always the first by default; for a real scroll-spy you'd add an
 * IntersectionObserver, but that's outside the prototype's scope.
 */
import { useTranslations } from '../../i18n/utils';

const t = useTranslations(Astro.currentLocale);

const tabs = [
  { num: 1, href: '#report', label: t('cf.tab.report'), active: true },
  { num: 2, href: '#ai', label: t('cf.tab.ai'), active: false },
  { num: 3, href: '#dashboard', label: t('cf.tab.dashboard'), active: false },
];
---

<!--
  Mobile: the row scrolls horizontally so all three pills stay readable instead
  of wrapping awkwardly under a narrow viewport. The hidden scrollbar keeps the
  visual clean. From sm+ the row centers and wraps naturally.
-->
<div
  class="mt-7 sm:mt-9 -mx-4 sm:mx-0 px-4 sm:px-0 flex sm:flex-wrap sm:justify-center overflow-x-auto sm:overflow-visible gap-2.5 fade-up delay-3 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
>
  {tabs.map((tab) => (
    <a
      href={tab.href}
      class:list={[
        'inline-flex items-center gap-2 shrink-0 px-3 sm:px-4 py-2.5 rounded-full text-[12px] sm:text-[13px] font-semibold transition-colors duration-150 border whitespace-nowrap',
        tab.active
          ? 'bg-navy text-white border-navy'
          : 'bg-white/70 text-text-soft border-line-strong hover:text-navy hover:border-navy',
      ]}
    >
      <span class={`grid place-items-center w-5 h-5 rounded-full text-[10px] font-bold ${tab.active ? 'bg-white/20 text-white' : 'bg-navy/10 text-navy'}`}>
        {tab.num}
      </span>
      {tab.label}
    </a>
  ))}
</div>
