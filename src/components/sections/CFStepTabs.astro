---
/**
 * CFStepTabs — three pill-tabs that anchor-link to the three scenario sections.
 *
 * Pure markup: each tab is just an `<a href="#anchor">`. The "active" tab is
 * always the first by default; for a real scroll-spy you'd add an
 * IntersectionObserver, but that's outside the prototype's scope.
 */
import { useTranslations } from '../../i18n/utils';

const t = useTranslations(Astro.currentLocale);

const tabs = [
  { num: 1, href: '#report', label: t('cf.tab.report'), active: true },
  { num: 2, href: '#ai', label: t('cf.tab.ai'), active: false },
  { num: 3, href: '#dashboard', label: t('cf.tab.dashboard'), active: false },
];
---

<div class="mt-9 flex flex-wrap gap-2.5 fade-up delay-3">
  {tabs.map((tab) => (
    <a
      href={tab.href}
      class:list={[
        'inline-flex items-center gap-2 px-4 py-2.5 rounded-full text-[13px] font-semibold transition-colors duration-150 border',
        tab.active
          ? 'bg-navy text-white border-navy'
          : 'bg-white/70 text-text-soft border-line-strong hover:text-navy hover:border-navy',
      ]}
    >
      <span class={`grid place-items-center w-5 h-5 rounded-full text-[10px] font-bold ${tab.active ? 'bg-white/20 text-white' : 'bg-navy/10 text-navy'}`}>
        {tab.num}
      </span>
      {tab.label}
    </a>
  ))}
</div>
