---
/**
 * CFHero — opening hero of the how-it-works page.
 *
 * Mirrors the landing Hero in shape (eyebrow pill + display headline +
 * paragraph) but stays single-column so the CFStepTabs can run below it as a
 * navigator into the three scenarios. The eyebrow uses the `eye` icon to hint
 * at "watch the flow" rather than the heart-pulse from the landing.
 */
import HeroEyebrow from '../ui/HeroEyebrow.astro';
import CFStepTabs from './CFStepTabs.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations(Astro.currentLocale);
---

<section class="cf-hero relative pt-16 pb-12 overflow-hidden text-center">
  <!-- Same soft halo treatment as the landing Hero, dialed down for a calmer top. -->
  <div class="cf-glow-a"></div>
  <div class="cf-glow-b"></div>

  <div class="shell relative z-10 max-w-4xl mx-auto">
    <div class="fade-up flex justify-center">
      <HeroEyebrow icon="eye">{t('cf.hero.eyebrow')}</HeroEyebrow>
    </div>
    <h1
      class="t-display fade-up delay-1 m-0 mb-6"
      set:html={t('cf.hero.title.html')}
    ></h1>
    <p class="text-[18px] leading-[1.55] text-text-soft max-w-160 mx-auto m-0 mb-2 fade-up delay-2">
      {t('cf.hero.body')}
    </p>
    <div class="flex justify-center">
      <CFStepTabs />
    </div>
  </div>
</section>

<style>
  .cf-glow-a {
    position: absolute;
    top: -180px;
    right: -160px;
    width: 640px;
    height: 640px;
    background: radial-gradient(circle at center, rgba(77, 168, 218, 0.16) 0%, rgba(77, 168, 218, 0) 60%);
    pointer-events: none;
    z-index: 0;
  }
  .cf-glow-b {
    position: absolute;
    bottom: -240px;
    left: -160px;
    width: 560px;
    height: 560px;
    background: radial-gradient(circle at center, rgba(165, 227, 216, 0.30) 0%, rgba(165, 227, 216, 0) 60%);
    pointer-events: none;
    z-index: 0;
  }
</style>
