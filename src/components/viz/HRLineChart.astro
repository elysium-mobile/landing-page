---
/**
 * HRLineChart — small SVG line chart used inside the HR phone "Mood" card.
 *
 * Pure SVG, no JS. The path is computed in the frontmatter from a hard-coded
 * data array (presentational only — the prototype shows mocked numbers).
 *
 * The area below the line is a gradient that fades the chart's colour to
 * transparent for a subtle filled-area effect.
 */
interface Props {
  /** Numeric series. Min/max are auto-derived. */
  data?: number[];
  /** CSS colour for the line + gradient base. */
  color?: string;
  /** Viewbox width (no real units; the chart scales to the parent). */
  width?: number;
  /** Viewbox height. */
  height?: number;
}

const {
  data = [6.8, 7.0, 6.8, 7.1, 7.2, 7.0, 7.3, 7.4, 7.2, 7.0, 6.9, 7.1, 7.2, 7.4, 7.5, 7.4, 7.5, 7.6, 7.6, 7.7, 7.6],
  color = 'var(--color-teal)',
  width = 340,
  height = 90,
} = Astro.props;

const pad = 8;
const max = Math.max(...data);
const min = Math.min(...data);
const range = Math.max(max - min, 0.001);

// Convert each data point to (x, y) inside the padded box.
const pts = data.map((v, i) => {
  const x = pad + (i / (data.length - 1)) * (width - pad * 2);
  const y = height - pad - ((v - min) / range) * (height - pad * 2);
  return [Number(x.toFixed(1)), Number(y.toFixed(1))] as const;
});

const linePath = pts
  .map(([x, y], i) => `${i === 0 ? 'M' : 'L'}${x} ${y}`)
  .join(' ');
const areaPath = `${linePath} L${pts[pts.length - 1][0]} ${height - pad} L${pts[0][0]} ${height - pad} Z`;

// Unique gradient id so multiple instances coexist.
const gid = `grad-${Math.random().toString(36).slice(2, 8)}`;
const last = pts[pts.length - 1];
---

<svg viewBox={`0 0 ${width} ${height}`} width="100%" height={height} preserveAspectRatio="none">
  <defs>
    <linearGradient id={gid} x1="0" x2="0" y1="0" y2="1">
      <stop offset="0%" stop-color={color} stop-opacity="0.28" />
      <stop offset="100%" stop-color={color} stop-opacity="0" />
    </linearGradient>
  </defs>
  <!-- Faint horizontal gridlines. -->
  {[0, 0.25, 0.5, 0.75, 1].map((p) => (
    <line
      x1={pad}
      x2={width - pad}
      y1={pad + p * (height - pad * 2)}
      y2={pad + p * (height - pad * 2)}
      stroke="#E4E8EE"
      stroke-dasharray="2 4"
    />
  ))}
  <path d={areaPath} fill={`url(#${gid})`} />
  <path d={linePath} fill="none" stroke={color} stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
  <!-- Last-value marker. -->
  <circle cx={last[0]} cy={last[1]} r="3.5" fill={color} stroke="white" stroke-width="2" />
</svg>
