---
/**
 * HRChartBars — six bar columns for the "Weather by team" mini chart.
 *
 * Hard-coded mock data; this is a presentational illustration, not a real
 * chart. Bars compute height as `v * 0.7%` so the tallest (88) lands at ~62%
 * of the 78px container, leaving room for the legend below.
 */
const data = [
  { l: 'Eng', v: 78, c: 'var(--color-teal)' },
  { l: 'Dis', v: 42, c: 'var(--color-warning)' },
  { l: 'Mkt', v: 84, c: 'var(--color-teal)' },
  { l: 'Vts', v: 71, c: 'var(--color-sky)' },
  { l: 'Ops', v: 66, c: 'var(--color-sky)' },
  { l: 'PM', v: 88, c: 'var(--color-teal)' },
];
---

<div class="flex items-end justify-between gap-1.5 h-19.5 mt-2">
  {data.map((d) => (
    <div class="flex-1 flex flex-col items-center gap-1.5">
      <div
        class="w-full rounded-t-md min-h-1.5 opacity-90"
        style={`height:${d.v * 0.7}%;background:${d.c};border-radius:6px 6px 2px 2px;`}
      ></div>
      <div class="text-[10px] text-text-soft font-medium">{d.l}</div>
    </div>
  ))}
</div>
