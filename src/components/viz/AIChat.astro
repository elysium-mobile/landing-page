---
/**
 * AIChat — auto-cycling demo conversation between a user and "Ely" (the bot).
 * (the landing page's IA viz block).
 *
 * Implementation: every step in the sequence is rendered server-side as a
 * sibling node inside the chat body, with `hidden` set by default. The
 * client tick just removes the `hidden` attribute on more nodes — there is
 * NO `innerHTML = …` mutation in the loop.
 *
 * Why: rewriting innerHTML every 2.2s caused a layout-shift cascade in dev
 * (with DevTools `Disable cache` on) that made the surrounding header/footer
 * `<img>` re-fetch on every tick. Pre-rendering eliminates the re-parse so
 * the surrounding DOM stays stable.
 *
 * Cycle behavior:
 *   - `step` walks 0 → seq.length, then wraps back to 0 (one extra empty
 *     beat — visual rest before restart).
 *   - When `document.hidden` we skip the tick instead of advancing.
 */
import { Icon } from 'astro-icon/components';
import AIInput from './AIInput.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations(Astro.currentLocale);

type Step = { kind: 'user' | 'bot' | 'typing'; text?: string };

const seq: Step[] = [
  { kind: 'user', text: t('chat.user1') },
  { kind: 'typing' },
  { kind: 'bot', text: t('chat.bot1') },
  { kind: 'user', text: t('chat.user2') },
  { kind: 'typing' },
  { kind: 'bot', text: t('chat.bot2') },
];
---

<div class="relative z-10 bg-surface rounded-(--radius-card) px-4.5 pt-4.5 pb-5.5 border border-navy/6" style="box-shadow:var(--shadow-card-lg);">
  <div class="flex items-center gap-3 pb-3.5 border-b border-line mb-3.5">
    <div class="relative w-10 h-10 rounded-[12px] grid place-items-center text-white" style="background:linear-gradient(135deg, var(--color-sky), var(--color-teal));">
      <Icon name="sparkles" width={20} height={20} />
      <!-- Live dot on the avatar. -->
      <span class="absolute -bottom-0.5 -right-0.5 w-3 h-3 rounded-full bg-teal border-2 border-white"></span>
    </div>
    <div>
      <div class="font-bold text-[14px] text-navy">{t('viz.ai.title')}</div>
      <div class="text-[11px] text-text-soft flex items-center gap-1">
        <span class="w-1.5 h-1.5 rounded-full bg-teal"></span> {t('viz.ai.status')}
      </div>
    </div>
  </div>

  <!--
    Pre-rendered messages with `hidden` by default. The client tick toggles
    the `hidden` attribute. `data-step={i}` lets the script address each one
    by its sequence index without rebuilding the list.
  -->
  <div
    class="flex flex-col gap-2.5 min-h-45"
    data-ai-msgs
    data-len={seq.length}
  >
    {seq.map((m, i) => {
      if (m.kind === 'typing') {
        return (
          <div data-step={i} data-kind="typing" hidden class="self-start bg-paper px-3.5 py-2.5 rounded-[14px] rounded-bl-sm inline-flex gap-1">
            <span class="w-1.5 h-1.5 rounded-full bg-text-mute" style="animation:bounce-dot 1.2s infinite;"></span>
            <span class="w-1.5 h-1.5 rounded-full bg-text-mute" style="animation:bounce-dot 1.2s infinite 0.15s;"></span>
            <span class="w-1.5 h-1.5 rounded-full bg-text-mute" style="animation:bounce-dot 1.2s infinite 0.3s;"></span>
          </div>
        );
      }
      // user / bot bubble. Asymmetric corner gives the speech-tail.
      const tone =
        m.kind === 'user'
          ? 'self-end bg-sky text-white rounded-br-[4px]'
          : 'self-start bg-paper text-ink rounded-bl-[4px]';
      return (
        <div data-step={i} hidden class:list={['max-w-[80%] px-3.5 py-2.5 rounded-[14px] text-[13px] leading-[1.45]', tone]}>
          {m.text}
        </div>
      );
    })}
  </div>

  <AIInput />
</div>

<script>
  // For each AIChat on the page, manage reveal by flipping `hidden` on the
  // pre-rendered nodes. No innerHTML rewriting → no parent layout cascade,
  // and surrounding `<img>` tags stay put.
  document.querySelectorAll<HTMLElement>('[data-ai-msgs]').forEach((root) => {
    const total = parseInt(root.dataset.len ?? '0', 10);
    const items = Array.from(root.querySelectorAll<HTMLElement>('[data-step]'));
    let step = 0;

    /** Show the first `step` items. Typing dots are special-cased: they stay
     *  visible only while they're the *tip* of the reveal — i.e. the next
     *  message hasn't landed yet. Once a later bubble appears, the dots hide
     *  so they don't linger above the actual reply. */
    const paint = () => {
      items.forEach((el, i) => {
        const isTyping = el.dataset.kind === 'typing';
        const isTip = i === step - 1;
        const visible = isTyping ? (i < step && isTip) : i < step;
        if (visible) el.removeAttribute('hidden');
        else el.setAttribute('hidden', '');
      });
    };

    paint();

    setInterval(() => {
      // Tab hidden → skip the frame. State doesn't advance; resumes when visible.
      if (document.hidden) return;
      // Walk 0..N, then back to 0 (one extra step shows nothing — visual rest).
      step = (step + 1) % (total + 1);
      paint();
    }, 2200);
  });
</script>
