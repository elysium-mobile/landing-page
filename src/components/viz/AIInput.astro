---
/**
 * AIInput — fake message input pinned at the bottom of the AI chat card.
 *
 * `<input readonly>` because it's purely cosmetic; clicking the Send button
 * does nothing in this prototype. Placeholder copy comes from i18n.
 */
import { Icon } from 'astro-icon/components';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations(Astro.currentLocale);
---

<div class="mt-3.5 flex items-center gap-2 bg-paper rounded-full pl-4 pr-1 py-1">
  <input
    type="text"
    readonly
    placeholder={t('viz.ai.input')}
    class="flex-1 bg-transparent border-none font-sans text-[13px] text-ink outline-none h-9"
  />
  <button type="button" class="w-9 h-9 rounded-full bg-sky text-white grid place-items-center transition-colors 
  duration-150 hover:bg-teal" aria-label="Send">
    <Icon name="send" width={14} height={14} />
  </button>
</div>
