---
/**
 * AISide — small "Private by design" badge floating to the left of the AI chat.
 *
 * Reinforces the privacy story while the cycling chat below it shows what the
 * AI actually does.
 */
import { useTranslations } from '../../i18n/utils';

const t = useTranslations(Astro.currentLocale);
---

<div
  class="absolute -left-7 top-65 w-45 z-20 bg-white rounded-3 px-3 py-2.5 text-[11px] border border-navy/6 max-md:left-2"
  style="box-shadow:var(--shadow-card-lg);animation:floaty 6s ease-in-out infinite;"
>
  <strong class="block font-bold text-navy text-[12px] mb-0.5">{t('viz.ai.side.title')}</strong>
  {t('viz.ai.side.body')}
</div>
