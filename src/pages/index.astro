---
/**
 * `/` — Spanish landing (default locale).
 *
 * Astro's i18n config has `defaultLocale: 'es'` and `prefixDefaultLocale: false`,
 * so this page is served at the root with `Astro.currentLocale === 'es'`.
 * Components downstream read that to choose which dictionary to use.
 *
 * The English version lives at `src/pages/en/index.astro` and renders the same
 * composition — both files are intentionally one-liners over BaseLayout so the
 * full landing structure stays in `src/components/sections/*`.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import SiteFooter from '../components/site/SiteFooter.astro';
import Hero from '../components/sections/Hero.astro';
import StatsStrip from '../components/sections/StatsStrip.astro';
import Benefits from '../components/sections/Benefits.astro';
import CTABanner from '../components/sections/CTABanner.astro';
---

<BaseLayout>
  <SiteHeader active="home" />
  <Hero />
  <StatsStrip />
  <Benefits />
  <CTABanner />
  <SiteFooter />
</BaseLayout>
